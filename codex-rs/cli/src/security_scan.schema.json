{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "tool",
    "schema_version",
    "generated_at",
    "scope",
    "findings"
  ],
  "properties": {
    "tool": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "required": [
        "root",
        "paths"
      ],
      "properties": {
        "root": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "base_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "title",
          "category",
          "severity",
          "confidence",
          "files",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "cwe": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "path"
              ],
              "properties": {
                "path": {
                  "type": "string"
                },
                "start_line": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 1
                },
                "end_line": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 1
                }
              },
              "additionalProperties": true
            }
          },
          "summary": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          },
          "evidence": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string"
              },
              "sink": {
                "type": "string"
              },
              "dataflow": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "why_not_mitigated": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "recommendation": {
            "type": "string"
          },
          "proposed_patch": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "diff": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "verification": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "method": {
                "type": "string"
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
